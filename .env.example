# Copy this file to .env and fill in your key.
# You only need one — Anthropic is preferred (faster, cheaper).

# Get a free key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here

# Or use Gemini (fallback) — https://aistudio.google.com
# GEMINI_API_KEY=your-gemini-key-here

# Optional: override the default Claude model
# ESPRESSO_CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional: show LLM debug logs
# ESPRESSO_LLM_VERBOSE=1
